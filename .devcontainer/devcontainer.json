{
    "name": "Python QA Engine",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "qa-engine",
    "workspaceFolder": "/usr/src/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "python.analysis.typeCheckingMode": "basic",
                "python.defaultInterpreterPath": "/usr/src/app/.venv/bin/python"
            }
        }
    }
}